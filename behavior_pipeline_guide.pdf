#!/bin/bash
# ============================================================
# Slurm JOB ARRAY: transcribe + diarize every WAV in a folder
# Target: CARC Laguna cluster (SoCal RCA)
#
# BEFORE FIRST USE — three values you must fill in:
#   1. --account   : your project ID (run `myaccount` on the
#                    cluster, or ask your PI)
#   2. --partition : Laguna's GPU partition name (run
#                    `sinfo` to list partitions; CARC's main
#                    cluster uses "gpu" but verify on Laguna)
#   3. --gpus-per-task : GPU type string if required, e.g.
#                    a100:1 — `noderes` or `sinfo -o "%G"` shows
#                    what's available
#
# SETUP (once):
#   mkdir -p ~/behavior-pipeline/{data,output,logs,containers}
#   # copy audio-stage.sif into ~/behavior-pipeline/containers/
#   # copy your WAVs into ~/behavior-pipeline/data/
#   export HF_TOKEN=hf_xxx   # put in ~/.bashrc on the cluster too
#
# SUBMIT:
#   cd ~/behavior-pipeline
#   N=$(ls data/*.wav | wc -l)
#   sbatch --array=0-$((N-1)) transcribe_array.slurm
#
# MONITOR:
#   squeue --me          # queue status
#   jobhist              # history (CARC custom command)
#   tail -f logs/transcribe_<jobid>_<task>.out
# ============================================================

#SBATCH --account=<project_id>
#SBATCH --partition=gpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --gpus-per-task=1
#SBATCH --mem=32G
#SBATCH --time=2:00:00
#SBATCH --job-name=whisperx-array
#SBATCH --output=logs/transcribe_%A_%a.out
#SBATCH --error=logs/transcribe_%A_%a.err

set -euo pipefail

# ------------------------------------------------------------
# Paths — adjust if your layout differs
# ------------------------------------------------------------
ROOT="${HOME}/behavior-pipeline"
DATA_DIR="${ROOT}/data"
OUT_DIR="${ROOT}/output"
SIF="${ROOT}/containers/audio-stage.sif"

mkdir -p "${OUT_DIR}" "${ROOT}/logs"

# ------------------------------------------------------------
# Map this array task to one WAV file
# Sorted glob ensures a stable index -> file mapping
# ------------------------------------------------------------
mapfile -t FILES < <(ls "${DATA_DIR}"/*.wav | sort)
WAV="${FILES[${SLURM_ARRAY_TASK_ID}]}"
BASE=$(basename "${WAV}" .wav)

echo "[$(date)] Task ${SLURM_ARRAY_TASK_ID} -> ${WAV}"
echo "Node: $(hostname) | GPU: ${CUDA_VISIBLE_DEVICES:-none}"

# ------------------------------------------------------------
# Sanity checks
# ------------------------------------------------------------
[[ -f "${SIF}" ]] || { echo "FATAL: container not found at ${SIF}"; exit 1; }
[[ -n "${HF_TOKEN:-}" ]] || { echo "FATAL: HF_TOKEN not set (needed for pyannote)"; exit 1; }

# Load apptainer if the cluster provides it as a module
# (harmless no-op if it's already on PATH)
module purge || true
module load apptainer 2>/dev/null || module load singularity 2>/dev/null || true

# ------------------------------------------------------------
# Run WhisperX inside the container
#   --nv           : GPU passthrough
#   --bind         : make data/output dirs visible inside
#   float16        : datacenter GPUs have VRAM to spare;
#                    this is faster and more accurate than
#                    the int8 you use on the 8GB laptop
# ------------------------------------------------------------
apptainer exec --nv \
    --bind "${DATA_DIR}:/data,${OUT_DIR}:/out" \
    "${SIF}" \
    whisperx "/data/$(basename "${WAV}")" \
        --model large-v3 \
        --compute_type float16 \
        --diarize \
        --hf_token "${HF_TOKEN}" \
        --output_dir "/out/${BASE}" \
        --output_format json

echo "[$(date)] Done: ${OUT_DIR}/${BASE}/"

# ------------------------------------------------------------
# Result: output/<session>/<session>.json per recording, each
# containing speaker-labeled, word-timestamped segments —
# the input format for the ConvoKit / NetworkX analysis stage.
# ------------------------------------------------------------
